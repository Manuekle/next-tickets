# Hugging Face Space Configuration
# Set these in Settings → Repository Secrets

# Database (use Supabase, Neon, or Railway)
DATABASE_URL=postgresql://user:pass@your-db-host:5432/next_tickets

# JWT (generate random strings: openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend URL (Vercel)
FRONTEND_URL=https://your-app.vercel.app

# Redis (optional — for queues, disable if not needed)
REDIS_URL=

# S3 Compatible Storage (Backblaze B2, AWS S3, or Cloudflare R2)
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=next-tickets
S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com

# SMTP Email (SendGrid, Mailgun, or Resend)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-api-key
EMAIL_FROM=noreply@nexttickets.com

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
